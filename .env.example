# ==========================================
# CodeGuardian AI - Environment Variables
# ==========================================
# Copy this to .env and fill in your values.

# --- GitHub ---
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# --- LLM Providers ---
GROQ_API_KEY=gsk_your_groq_api_key_here
# CLAUDE_API_KEY=sk-ant-your_claude_key_here  # Optional fallback

# --- Database ---
DATABASE_URL=postgresql+psycopg2://codeguardian:codeguardian@localhost:5432/codeguardian
DATABASE_URL_ASYNC=postgresql+asyncpg://codeguardian:codeguardian@localhost:5432/codeguardian

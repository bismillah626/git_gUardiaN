# ==========================================
# Git Guardian AI - Environment Variables
# ==========================================
# Copy this to .env and fill in your values.

# --- GitHub ---
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# --- LLM Providers ---
GROQ_API_KEY=gsk_your_groq_api_key_here
# CLAUDE_API_KEY=sk-ant-your_claude_key_here  # Optional fallback

# --- Database ---
DATABASE_URL=postgresql+psycopg2://git_guardian:git_guardian@localhost:5432/git_guardian
DATABASE_URL_ASYNC=postgresql+asyncpg://git_guardian:git_guardian@localhost:5432/git_guardian
